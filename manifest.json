{
    "manifest_version": 3,
    "name": "Always Active Media",
    "version": "1.1",
    "description": "Stops Instagram and Reddit from pausing media when you switch tabs.",
    "content_scripts": [
        {
            "matches": [
                "https://*.instagram.com/*",
                "https://*.reddit.com/*"
            ],
            "js": [
                "content.js"
            ],
            "run_at": "document_start",
            "world": "MAIN"
        }
    ]
}